  bash   Add to ~/.bashrc:    eval \"\$(cmt completions bash)\"
  zsh    Add to ~/.zshrc:     eval \"\$(cmt completions zsh)\"
  fish   Add to config.fish:  cmt completions fish | source

${BOLD}INTEGRATIONS${RESET}
  Husky v9    cmt init --husky  →  .husky/prepare-commit-msg  (commit it, team shares it)
  lint-staged add to .husky/pre-commit:  npx lint-staged
  GitHub CI   echo \"\$(git log -1 --format=%s)\" | cmt lint

${BOLD}CONFIG${RESET}  .cmt.json  (JSON Schema → intellisense in VS Code / JetBrains)
  {
    \"customTypes\": [{ \"type\": \"wip\", \"emoji\": \"🚧\", \"semver\": \"none\", \"description\": \"...\" }],
    \"scopes\":      [\"auth\", \"api\", \"ui\"],
    \"rules\":       { \"maxHeaderLength\": 72, \"requireScope\": false }
  }

"
}

# dispatch
main() {
  local cmd="${1:-commit}"
  [[ $# -gt 0 ]] && shift
  case "$cmd" in
    commit|c)        cmd_commit "$@" ;;
    amend|a)         cmd_amend "$@" ;;
    lint|l)          cmd_lint "$@" ;;
    init)            cmd_init "$@" ;;
    log)             cmd_log "$@" ;;
    status|s)        cmd_status "$@" ;;
    types|t)         cmd_types "$@" ;;
    completions)     cmd_completions "$@" ;;
    uninstall)       cmd_uninstall "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help|*) cmd_help ;;
  esac
}

# Allow sourcing for tests without executing main
[[ "${CMT_SOURCED:-0}" == "1" ]] && return 0
main "$@"

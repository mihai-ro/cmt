{
  "release-type": "simple",
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "@mihairo/cmt",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "cmt",
          "searchBy": "string",
          "data": [
            {
              "before": "CC_VERSION=\"",
              "after": "\""
            }
          ]
        },
        {
          "type": "generic",
          "path": "README.md",
          "searchBy": "string",
          "data": [
            {
              "before": "\"version\": \"",
              "after": "\","
            }
          ]
        },
        {
          "type": "json",
          "path": ".cmt.example.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "schema/cmt.schema.json",
          "searchBy": "string",
          "data": [
            {
              "before": "Currently '",
              "after": "'."
            },
            {
              "before": "\"default\": \"",
              "after": "\","
            },
            {
              "before": "\"examples\": [\"",
              "after": "\"]"
            },
            {
              "before": "\"version\": \"",
              "after": "\","
            }
          ]
        }
      ]
    }
  }
}
